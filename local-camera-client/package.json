{
  "name": "ghost-local-camera-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main.cjs",
  "scripts": {
    "dev": "npm run build && set \"ELECTRON_RUN_AS_NODE=\" && electron .",
    "build": "tsc -p tsconfig.json && node scripts/copy-preload.cjs",
    "start": "set \"ELECTRON_RUN_AS_NODE=\" && electron .",
    "start:worker": "node dist/index.js",
    "test": "vitest run --pool=threads",
    "build:exe": "node scripts/validate-hikvision-sdk.cjs && node scripts/copy-hikvision-sdk.cjs && npm run build && electron-builder --win nsis --x64",
    "build:portable": "node scripts/validate-hikvision-sdk.cjs && node scripts/copy-hikvision-sdk.cjs && npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "node-windows": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "esbuild": "^0.25.0",
    "vitest": "^4.1.1"
  },
  "build": {
    "appId": "com.ghost.camera-agent",
    "productName": "GHOST Camera Agent",
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "dist/hikvision-helper.cjs"
    ],
    "extraResources": [
      {
        "from": "hikvision-sdk",
        "to": "hikvision-sdk",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "build"
    },
    "win": {
      "icon": "ghost.ico",
      "target": "nsis",
      "artifactName": "GHOST-Camera-Agent-Setup-${version}-${arch}.${ext}"
    },
    "protocols": [
      {
        "name": "GHOST Agent Provisioning",
        "schemes": [
          "ghost-agent"
        ]
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "include": "scripts/installer.nsh"
    }
  }
}
