# העתק לקובץ .env (באותה תיקייה) והשלם ערכים. ללא OPENAI_API_KEY שרת ה-proxy יעלה אך יחזיר 503 לניתוח.
OPENAI_API_KEY=
PORT=8787
REDIS_URL=redis://localhost:6379
OPENAI_MODEL_DEFAULT=gpt-4.1-mini
OPENAI_MODEL_COMPLEX=gpt-4.1
QUEUE_CONCURRENCY=2
QUEUE_RATE_LIMIT_RPM=50
SUPER_ADMIN_USERNAME=omeradmin
SUPER_ADMIN_PASSWORD=omeradmin
SUPER_ADMIN_MANAGER_CODE=1553
GHOST_FIREBASE_WEB_API_KEY=
JWT_ACCESS_SECRET=replace-me-access-secret
JWT_REFRESH_SECRET=replace-me-refresh-secret
ADMIN_ENCRYPTION_SECRET=replace-me-encryption-secret
